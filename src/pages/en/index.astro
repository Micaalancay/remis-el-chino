---
import Layout from '../../layouts/Layout.astro';
import WhatsAppBtn from '../../components/WhatsAppBtn.astro';
import QuienesSomos from '../../components/QuienesSomos.astro'; 
// Datos de los traslados simples
const traslados = [
  { destino: "Aeropuerto Salta", precio: "$15.000", nota: "Servicio 24hs" },
  { destino: "Paso de Jama", precio: "Consultar", nota: "Traslado Internacional" },
  { destino: "Tilcara / Humahuaca", precio: "$80.000", nota: "Desde Purmamarca" },
  { destino: "Susques", precio: "Consultar", nota: "Puna Jujeña" },
];
---

<Layout title="Aldineho | Traslados y Excursiones en Salta y Jujuy">
  
  <section class="relative bg-slate-900 py-20 px-6 overflow-hidden">
    <div class="max-w-5xl mx-auto text-center relative z-10">
      <span class="text-orange-500 font-bold tracking-widest uppercase text-sm">Salta & Jujuy · Argentina</span>
      <h1 class="text-5xl md:text-7xl font-black text-white mt-4 mb-6 leading-tight">
        Tu viaje al Norte, <br/> <span class="text-orange-500">sin preocupaciones.</span>
      </h1>
      <p class="text-xl text-slate-300 max-w-2xl mx-auto mb-10">
        Traslados privados y excursiones personalizadas. Te buscamos por tu alojamiento y te llevamos a los paisajes más increíbles del país.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="#excursiones" class="bg-orange-600 hover:bg-orange-500 text-white font-bold py-4 px-8 rounded-full transition-all shadow-lg shadow-orange-900/20">
          Ver Excursiones
        </a>
        <a href="#traslados" class="bg-white/10 hover:bg-white/20 text-white backdrop-blur-md font-bold py-4 px-8 rounded-full transition-all">
          Precios de Traslados
        </a>
      </div>
    </div>
  </section>

  <QuienesSomos />

  <section id="excursiones" class="py-20 px-6 bg-gray-50">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-4xl font-black text-slate-900">Excursión Estrella</h2>
        <p class="text-slate-500 mt-2">Un recorrido inolvidable de 8 horas</p>
      </div>

      <div class="bg-white rounded-[2.5rem] shadow-2xl shadow-slate-200 overflow-hidden border border-slate-100">
        <div class="bg-orange-600 p-8 md:p-12 text-white">
          <div class="flex flex-col md:flex-row justify-between items-start gap-6">
            <div>
              <h3 class="text-4xl font-black">Purmamarca al Hornocal</h3>
              <p class="text-orange-100 text-lg mt-2 italic">Cerro de los 14 Colores</p>
            </div>
            <div class="bg-white/20 backdrop-blur-md p-4 rounded-2xl text-center min-w-[180px]">
              <p class="text-xs uppercase font-bold opacity-80">Precio por Auto</p>
              <p class="text-4xl font-black">$240.000</p>
              <p class="text-[10px] mt-1 italic">Hasta 4 pasajeros</p>
            </div>
          </div>
        </div>

        <div class="p-8 md:p-12">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div>
              <h4 class="font-bold text-slate-900 text-xl mb-6 flex items-center gap-2">
                <span class="bg-orange-100 p-2 rounded-lg text-orange-600 text-sm">📋</span> Itinerario Detallado
              </h4>
              <ul class="space-y-4 text-slate-600">
                <li class="flex gap-3"><strong>🌵 Huacalera:</strong> Trópico de Capricornio</li>
                <li class="flex gap-3"><strong>🌵 Uquia:</strong> Ángeles Arcabuceros y fotos con Llamas</li>
                <li class="flex gap-3"><strong>🌵 Cultura:</strong> Clases de arcilla y degustación de vinos/quesos</li>
                <li class="flex gap-3"><strong>🌵 Humahuaca:</strong> Bendición de San Francisco (12:00hs)</li>
                <li class="flex gap-3"><strong>🌵 El Hornocal:</strong> Mirador a 4.350 m.s.n.m.</li>
              </ul>
            </div>
            <div class="bg-slate-50 p-6 rounded-3xl space-y-4">
              <h4 class="font-bold text-slate-900">Horarios y Datos</h4>
              <div class="flex justify-between border-b border-slate-200 py-2">
                <span class="text-slate-500">Salida:</span>
                <span class="font-bold">08:30 AM</span>
              </div>
              <div class="flex justify-between border-b border-slate-200 py-2">
                <span class="text-slate-500">Regreso:</span>
                <span class="font-bold">17:30 PM</span>
              </div>
              <div class="flex justify-between border-b border-slate-200 py-2">
                <span class="text-slate-500">Duración:</span>
                <span class="font-bold">8 Horas</span>
              </div>
              <p class="text-[11px] text-slate-400 italic pt-4">
                * No incluye entradas, comidas ni bebidas. Lo pasamos a buscar por su alojamiento.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="salinas" class="pb-20 px-6 bg-gray-50">
  <div class="max-w-4xl mx-auto">
    <div class="bg-white rounded-[2.5rem] shadow-2xl shadow-slate-200 overflow-hidden border border-slate-100">
      <div class="bg-cyan-600 p-8 md:p-12 text-white">
        <div class="flex flex-col md:flex-row justify-between items-start gap-6">
          <div>
            <h3 class="text-4xl font-black">Purmamarca a Salinas Grandes</h3>
            <p class="text-cyan-100 text-lg mt-2 italic">Cuesta del Lipán y el Desierto de Sal</p>
          </div>
          <div class="bg-white/20 backdrop-blur-md p-4 rounded-2xl text-center min-w-[180px]">
            <p class="text-xs uppercase font-bold opacity-80">Precio por Auto</p>
            <p class="text-4xl font-black">$45.000</p> 
            <p class="text-[10px] mt-1 italic">Hasta 4 pasajeros</p>
          </div>
        </div>
      </div>

      <div class="p-8 md:p-12">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div>
            <h4 class="font-bold text-slate-900 text-xl mb-6 flex items-center gap-2">
              <span class="bg-cyan-100 p-2 rounded-lg text-cyan-600 text-sm">📍</span> Itinerario Salinas
            </h4>
            <ul class="space-y-4 text-slate-600">
              <li class="flex gap-3"><strong>🏔️ Cuesta del Lipán:</strong> Ascenso hasta los 4.170 msnm</li>
              <li class="flex gap-3"><strong>📷 Mirador del Cóndor:</strong> Parada para fotos panorámicas</li>
              <li class="flex gap-3"><strong>⚪ Salinas Grandes:</strong> Caminata por los piletones de sal</li>
              <li class="flex gap-3"><strong>🚗 Regreso:</strong> Bajada con vista a los picos nevados</li>
            </ul>
          </div>
          <div class="bg-slate-50 p-6 rounded-3xl space-y-4">
            <h4 class="font-bold text-slate-900">Horarios y Datos</h4>
            <div class="flex justify-between border-b border-slate-200 py-2">
              <span class="text-slate-500">Duración:</span>
              <span class="font-bold">4 Horas aprox.</span>
            </div>
            <div class="flex justify-between border-b border-slate-200 py-2">
              <span class="text-slate-500">Frecuencia:</span>
              <span class="font-bold">Mañana o Tarde</span>
            </div>
            <p class="text-[11px] text-slate-400 italic pt-4">
              * Nota: Se recomienda llevar protector solar y lentes de sol por el reflejo de la sal.
            </p>
          </div>
        </div>
        
        <div class="mt-10">
          <a href="https://wa.me/549387XXXXXXX?text=Hola! Quiero consultar por el traslado a Salinas Grandes" 
             class="block w-full text-center bg-cyan-600 hover:bg-cyan-500 text-white font-bold py-4 rounded-2xl transition-all shadow-lg shadow-cyan-200">
             Consultar Disponibilidad
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

  <section id="traslados" class="py-20 px-6 bg-white">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-black text-slate-900 mb-10 text-center">Otros Traslados</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {traslados.map((item) => (
          <div class="p-6 border border-slate-100 bg-slate-50 rounded-2xl hover:border-orange-200 hover:bg-orange-50 transition-all group">
            <h4 class="font-bold text-slate-800 group-hover:text-orange-700">{item.destino}</h4>
            <p class="text-2xl font-black text-slate-900 my-2">{item.precio}</p>
            <p class="text-xs text-slate-400 font-medium uppercase tracking-tighter">{item.nota}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <footer class="bg-slate-900 py-12 px-6 text-center border-t border-white/5">
    <p class="text-slate-500 text-sm">© 2026 Aldineho Traslados - Salta, Argentina.</p>
    <p class="text-slate-600 text-xs mt-2">Diseñado por Alancay Software & Web </p>
  </footer>
  
  <WhatsAppBtn />

</Layout>