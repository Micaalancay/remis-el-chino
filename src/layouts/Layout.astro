---
import '../styles/global.css';

interface Props {
  title?: string;
  lang?: string;
  description?: string;
}

const { 
  lang = "es",
  title = lang === 'es' ? "Remis El Chino | Traslados y Excursiones en Purmamarca y Jujuy" : "Remis El Chino | Transfers and Excursions in Jujuy",
  description = lang === 'es' 
    ? "Remis en Purmamarca y Jujuy. Traslados privados al Aeropuerto, Salinas Grandes y Hornocal. Seguridad y puntualidad en el Norte Argentino."
    : "Private transfers in Purmamarca and Jujuy. Trips to the Airport, Salinas Grandes and Hornocal. Safety and punctuality in Northern Argentina."
} = Astro.props;

//  ARREGLADO: Se define la URL base del sitio web para construir la URL canónica correctamente
const baseUrl = "https://remiselchino.com.ar"; 

// DINÁMICO: Detecta la ruta actual para armar la URL canónica perfecta
const pathname = Astro.url.pathname;
const canonicalUrl = `${baseUrl}${pathname}`;
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="remis purmamarca, remis jujuy, traslados purmamarca, excursiones hornocal, salinas grandes remis, transfer aeropuerto jujuy, taxi purmamarca" />
    
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${baseUrl}/og-image.jpg`} /> 
    
    <!-- CORREGIDO: Canónica dinámica para evitar errores de duplicados en Google -->
    <link rel="canonical" href={canonicalUrl} />

    <script type="application/ld+json" is:inline define:vars={{ baseUrl }}>
      {
        "@context": "https://schema.org",
        "@type": "TaxiService",
        "name": "Remis El Chino",
        "description": "Servicio de traslados y excursiones en Purmamarca, Jujuy.",
        "provider": {
          "@type": "LocalBusiness",
          "name": "Remis El Chino",
          "address": {
            "@type": "PostalAddress",
            "addressLocality": "Purmamarca",
            "addressRegion": "Jujuy",
            "addressCountry": "AR"
          },
          "telephone": "+549388154153744"
        },
        "areaServed": [
          { "@type": "AdministrativeArea", "name": "Purmamarca" },
          { "@type": "AdministrativeArea", "name": "Jujuy" },
          { "@type": "AdministrativeArea", "name": "Salta" },
          { "@type": "AdministrativeArea", "name": "Tilcara" },
          { "@type": "AdministrativeArea", "name": "Humahuaca" }
        ],
        "url": "https://remiselchino.com.ar"
      }
    </script>
  </head>

  <body class="bg-gray-50 text-slate-900 selection:bg-orange-500 selection:text-white antialiased">
    <nav class="fixed top-6 right-6 z-[100] flex gap-1 bg-slate-900/80 backdrop-blur-xl p-1.5 rounded-2xl border border-white/10 shadow-2xl">
      <a 
        href="/" 
        class={`px-4 py-2 rounded-xl text-xs font-black transition-all ${lang === 'es' ? 'bg-orange-600 text-white shadow-lg shadow-orange-900/20' : 'text-slate-400 hover:text-white'}`}
      >
        ES
      </a>
      <a 
        href="/en" 
        class={`px-4 py-2 rounded-xl text-xs font-black transition-all ${lang === 'en' ? 'bg-orange-600 text-white shadow-lg shadow-orange-900/20' : 'text-slate-400 hover:text-white'}`}
      >
        EN
      </a>
    </nav>

    <slot /> 
  </body>
</html>