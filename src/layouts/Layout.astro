---
import '../styles/global.css';

interface Props {
  title?: string;
  lang?: string;
}

const { 
  title = "Remis El Chino | Traslados y Excursiones en Jujuy", 
  lang = "es" 
} = Astro.props;

// Cambiamos la URL base al nuevo dominio
const siteUrl = "https://remiselchino.com.ar";
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <title>{title}</title>
    <meta name="description" content="Remis El Chino: Traslados privados y excursiones personalizadas en Jujuy y Salta. Viajes al Aeropuerto, Salinas Grandes, Hornocal y toda la Quebrada. Seguridad y puntualidad." />
    <meta name="keywords" content="remis el chino, traslados jujuy, transfer aeropuerto jujuy, excursiones jujuy, purmamarca, hornocal, salinas grandes, remis purmamarca" />
    
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content="Viajá seguro con Remis El Chino. Traslados privados en el Norte Argentino." />
    <meta property="og:image" content={`${siteUrl}/og-image.jpg`} /> 
    
    <link rel="canonical" href={siteUrl} />
  </head>

  <body class="bg-gray-50 text-slate-900 selection:bg-orange-500 selection:text-white antialiased">
    <nav class="fixed top-6 right-6 z-[100] flex gap-1 bg-slate-900/80 backdrop-blur-xl p-1.5 rounded-2xl border border-white/10 shadow-2xl">
      <a 
        href="/" 
        class={`px-4 py-2 rounded-xl text-xs font-black transition-all ${lang === 'es' ? 'bg-orange-600 text-white shadow-lg shadow-orange-900/20' : 'text-slate-400 hover:text-white'}`}
      >
        ES
      </a>
      <a 
        href="/en" 
        class={`px-4 py-2 rounded-xl text-xs font-black transition-all ${lang === 'en' ? 'bg-orange-600 text-white shadow-lg shadow-orange-900/20' : 'text-slate-400 hover:text-white'}`}
      >
        EN
      </a>
    </nav>

    <slot /> 
  </body>
</html>