---
// src/components/Footer.astro
const { lang = 'es' } = Astro.props;
const currentYear = new Date().getFullYear();

const t = {
  es: {
    rights: "Todos los derechos reservados.",
    location: "Jujuy, Argentina",
    tagline: "Servicio profesional de traslados y excursiones privadas.",
    dev: "Diseño & Desarrollo",
    contact: "Contacto Directo",
    follow: "Seguinos",
  },
  en: {
    rights: "All rights reserved.",
    location: "Jujuy, Argentina",
    tagline: "Professional private transfer and excursion service.",
    dev: "Design & Development",
    contact: "Direct Contact",
    follow: "Follow us",
  }
}[lang];


const links = {
  instagram: "https://www.instagram.com/remiss_el_chino", 
  googleMaps: "https://maps.app.goo.gl/WR1q4nERHSEZcatR7", 
  email: "remisselchino@gmail.com"
};
---

<footer class="bg-slate-900 pt-16 pb-8 px-6 border-t border-white/5 text-white">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12 text-center md:text-left items-center md:items-start">
      
      <div class="flex flex-col items-center md:items-start">
        <h3 class="text-4xl font-black italic tracking-tighter text-orange-500 mb-2 leading-none">
          REMIS EL CHINO
        </h3>
        <p class="text-slate-400 text-sm font-medium leading-relaxed max-w-xs">
          {t.tagline}
        </p>
      </div>

      <div class="flex flex-col items-center gap-4">
        <h4 class="text-xs font-black uppercase tracking-[0.3em] text-slate-500">{t.follow}</h4>
        <div class="flex gap-8">
          <a href={links.instagram} target="_blank" rel="noopener noreferrer" class="group flex flex-col items-center gap-2">
            <div class="p-4 rounded-2xl bg-white/5 group-hover:bg-orange-500 group-hover:scale-110 transition-all duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-instagram"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
            </div>
            <span class="text-[9px] font-black tracking-widest text-slate-500 group-hover:text-white transition-colors">INSTAGRAM</span>
          </a>

          <a href={links.googleMaps} target="_blank" rel="noopener noreferrer" class="group flex flex-col items-center gap-2">
            <div class="p-4 rounded-2xl bg-white/5 group-hover:bg-orange-500 group-hover:scale-110 transition-all duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-map-pin"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <span class="text-[9px] font-black tracking-widest text-slate-500 group-hover:text-white transition-colors">UBICACIÓN</span>
          </a>
        </div>
      </div>

      <div class="flex flex-col items-center md:items-end gap-1">
        <h4 class="text-xs font-black uppercase tracking-[0.3em] text-slate-500 mb-2">{t.contact}</h4>
        <p class="text-slate-200 font-bold text-lg italic">{t.location}</p>
        <a 
          href={`mailto:${links.email}`} 
          class="text-orange-500 font-black tracking-widest text-sm hover:text-orange-400 transition-colors"
        >
          {links.email}
        </a>
        <div class="flex flex-wrap justify-center md:justify-end gap-2 mt-4 opacity-3000">
           {['Salta', 'Jujuy', 'Purmamarca', 'Humahuaca'].map(city => (
             <span class="text-slate-500 text-[9px] uppercase font-bold border border-slate-700 px-2 py-1 rounded-md">
               {city}
             </span>
           ))}
        </div>
      </div>
    </div>

    <div class="border-t border-white/5 pt-8 flex flex-col md:flex-row justify-between items-center gap-6">
      <p class="text-slate-500 text-[10px] uppercase tracking-[0.2em] italic font-medium">
        © {currentYear} REMIS EL CHINO — {t.rights}
      </p>

      <div class="group">
        <a href="https://www.linkedin.com/in/micaela-romina-alancay" target="_blank" class="text-slate-500 text-[10px] uppercase tracking-widest flex items-center gap-2">
          {t.dev} 
          <span class="text-slate-300 font-black group-hover:text-orange-500 transition-all duration-300">
            Alancay Software & Web
          </span>
        </a>
      </div>
    </div>
  </div>
</footer>