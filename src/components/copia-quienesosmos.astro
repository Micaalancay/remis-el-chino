---
const { lang = 'es' } = Astro.props;

const t = {
  es: {
    badge: "Sobre nosotros",
    title: "Experiencia Real en el Norte Argentino",
    p1: "En Remis El Chino, no solo ofrecemos traslados; ofrecemos la tranquilidad de viajar con gente que conoce cada rincón de Jujuy.",
    p2: "Somos un equipo local apasionado por nuestra tierra. Nuestro objetivo es que tu única preocupación sea disfrutar del paisaje mientras nosotros nos encargamos de que llegues a destino de forma segura, puntual y confortable.",
    stat: "Locales y Seguros"
  },
  en: {
    badge: "About us",
    title: "Real Experience in Northern Argentina",
    p1: "At Remis El Chino, we don't just offer transfers; we offer the peace of mind of traveling with people who know every corner of Jujuy.",
    p2: "We are a local team passionate about our land. Our goal is for your only concern to be enjoying the scenery while we ensure you arrive at your destination safely, on time, and comfortably.",
    stat: "Local & Safe"
  }
}[lang];
---

<section id="nosotros" class="py-24 px-6 bg-white overflow-hidden">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      
      <div class="relative">
        <div class="absolute -bottom-8 -right-8 bg-slate-900 p-8 rounded-[2.5rem] text-center shadow-2xl z-20 border border-white/10 scale-90 md:scale-100">
          <p class="text-5xl font-black text-orange-500 tracking-tighter">100%</p>
          <p class="text-[10px] uppercase font-black text-slate-400 tracking-widest mt-1 whitespace-nowrap">{t.stat}</p>
        </div>

        <div class="relative z-10 rounded-[3rem] overflow-hidden shadow-2xl transform -rotate-1 hover:rotate-0 transition-transform duration-500">
          <img 
            src="/img/excursiones/aldhineo.webp" 
            alt="Aldineho Team" 
            class="w-full h-[500px] object-cover"
          />
        </div>

        <div class="absolute -top-4 -left-4 w-24 h-24 bg-orange-100 rounded-full -z-10 blur-2xl opacity-60"></div>
      </div>

      <div class="flex flex-col gap-6">
        <span class="text-orange-600 font-black uppercase tracking-[0.3em] text-sm">{t.badge}</span>
        <h2 class="text-5xl md:text-6xl font-black text-slate-900 leading-[0.9] italic uppercase tracking-tighter">
          {t.title}
        </h2>
        
        <div class="w-20 h-2 bg-orange-600 rounded-full my-2"></div>
        
        <p class="text-xl text-slate-600 font-medium leading-relaxed italic">
          "{t.p1}"
        </p>
        
        <p class="text-slate-500 leading-relaxed font-medium">
          {t.p2}
        </p>

        <div class="mt-4">
          <a href="#contacto" class="inline-flex items-center gap-2 font-black text-slate-900 group">
            <span class="border-b-4 border-orange-500 group-hover:bg-orange-500 group-hover:text-white transition-all px-1">
              {lang === 'es' ? 'TRABAJEMOS JUNTOS' : 'LET\'S WORK TOGETHER'}
            </span>
            <span class="text-orange-500">→</span>
          </a>
        </div>
      </div>

    </div>
  </div>
</section>