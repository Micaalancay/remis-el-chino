---
import data from '../data/contenido.json';
const { lang = 'es' } = Astro.props;

const t = {
  es: { title: "Preguntas Frecuentes" },
  en: { title: "FAQ" }
}[lang];
---

<section class="py-24 px-6 bg-white">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-4xl font-black text-slate-900 mb-12 italic uppercase tracking-tighter text-center">{t.title}</h2>
    <div class="space-y-4">
      {data.faqs.map((faq) => (
        <div class="group border border-slate-100 bg-slate-50 rounded-[2rem] overflow-hidden transition-all hover:border-orange-200">
          <details class="w-full">
            <summary class="flex justify-between items-center p-8 cursor-pointer list-none [&::-webkit-details-marker]:hidden">
              <span class="text-xl font-black text-slate-800 group-open:text-orange-600 italic transition-colors">
                {faq[lang].q}
              </span>
              <span class="text-orange-600 transition-transform group-open:rotate-180">▼</span>
            </summary>
            <div class="px-8 pb-8 text-slate-600 font-medium">
              {faq[lang].a}
            </div>
          </details>
        </div>
      ))}
    </div>
  </div>
</section>