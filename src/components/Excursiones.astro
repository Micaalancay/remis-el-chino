---
// src/components/Excursiones.astro
import data from '../data/contenido.json';
const { lang = 'es' } = Astro.props;

// Textos fijos que no están en el JSON de cada excursión (etiquetas generales)
const t = {
  es: {
    badge: "Excursiones Destacadas",
    subtitle: "Recorridos diseñados para disfrutar de la Puna sin prisa",
    priceLabel: "Precio por Auto",
    itinerary: "Itinerario Detallado",
    infoTitle: "Horarios y Datos",
    disclaimer: "* No incluye entradas, comidas ni bebidas. Lo pasamos a buscar por su alojamiento.",
    labels: {
      salida: "Salida:",
      regreso: "Regreso:",
      duracion: "Duración:",
      horarios: "Horarios:"
    }
  },
  en: {
    badge: "Featured Excursions",
    subtitle: "Tours designed to enjoy the Puna without rushing",
    priceLabel: "Price per Car",
    itinerary: "Detailed Itinerary",
    infoTitle: "Schedule & Info",
    disclaimer: "* Does not include tickets, meals or drinks. Pick up at your accommodation.",
    labels: {
      salida: "Departure:",
      regreso: "Return:",
      duracion: "Duration:",
      horarios: "Schedule:"
    }
  }
}[lang];

const { hornocal, salinas } = data.excursiones;
---

<section id="excursiones" class="py-24 px-6 bg-slate-50">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-20">
      <h2 class="text-5xl font-black text-slate-900 tracking-tighter uppercase italic">{t.badge}</h2>
      <div class="w-24 h-2 bg-orange-600 mx-auto mt-4 rounded-full"></div>
      <p class="text-slate-500 mt-6 text-xl font-medium">{t.subtitle}</p>
    </div>

    <div class="bg-white rounded-[3rem] shadow-2xl shadow-slate-200 overflow-hidden border border-slate-100 flex flex-col mb-24 transition-transform hover:scale-[1.01] duration-500">
      <div class="bg-orange-600 p-10 md:p-14 text-white relative overflow-hidden">
        <div class="absolute right-0 top-0 opacity-10 text-9xl font-black -mr-10 -mt-10 select-none italic">HORNOCAL</div>
        <div class="flex flex-col md:flex-row justify-between items-start gap-8 relative z-10">
          <div>
            <h3 class="text-4xl md:text-5xl font-black italic leading-tight uppercase">{hornocal[lang].titulo}</h3>
            <p class="text-orange-100 text-xl mt-4 font-medium opacity-90">{hornocal[lang].tag}</p>
          </div>
          <div class="bg-white/20 backdrop-blur-xl px-8 py-6 rounded-[2.5rem] text-center w-fit mx-auto border border-white/30 shadow-xl flex flex-col items-center justify-center">
            <p class="text-[10px] uppercase font-black tracking-[0.2em] opacity-80 mb-2 whitespace-nowrap">{t.priceLabel}</p>
            
            <p class="text-4xl md:text-5xl font-black tracking-tighter leading-none whitespace-nowrap px-2">
              {hornocal.precio}
            </p>
            
            <p class="text-[10px] mt-3 uppercase font-bold tracking-widest whitespace-nowrap opacity-90 border-t border-white/20 pt-2">
              Hasta {hornocal.pax} pasajeros
            </p>
          </div>
         
        </div>
      </div>

      <div class="grid grid-cols-3 gap-3 p-6 bg-slate-100">
        <div class="aspect-video overflow-hidden rounded-2xl border-4 border-white shadow-lg"><img src="/img/excursiones/purmamarca.webp" alt="Salinas" class="w-full h-full object-cover"></div>
        <div class="aspect-video overflow-hidden rounded-2xl border-4 border-white shadow-lg"><img src="/img/excursiones/hornocal-cerro.webp" alt="Lipan" class="w-full h-full object-cover"></div>
        <div class="aspect-video overflow-hidden rounded-2xl border-4 border-white shadow-lg"><img src="/img/excursiones/cerro.webp" alt="Fotos" class="w-full h-full object-cover"></div>
      </div>

      <div class="p-10 md:p-14">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
          <div>
            <h4 class="font-black text-slate-900 text-2xl mb-8 flex items-center gap-3 italic">
              <span class="bg-orange-600 text-white w-10 h-10 flex items-center justify-center rounded-xl text-sm">01</span>
              {t.itinerary}
            </h4>
            <ul class="space-y-5">
              {hornocal[lang].itinerario.map(item => (
                <li class="flex items-center gap-4 text-slate-700 font-bold">
                  <span class="w-2 h-2 bg-orange-500 rounded-full"></span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
          <div class="bg-slate-900 text-white p-10 rounded-[2.5rem] shadow-2xl transform lg:rotate-2 hover:rotate-0 transition-transform duration-500">
            <h4 class="font-black text-2xl mb-6 italic text-orange-500 uppercase">{t.infoTitle}</h4>
            <div class="space-y-4 font-medium">
              <div class="flex justify-between border-b border-white/10 pb-3">
                <span class="text-slate-400">{t.labels.salida}</span> <span class="font-bold text-orange-100 italic">{hornocal.salida}</span>
              </div>
              <div class="flex justify-between border-b border-white/10 pb-3">
                <span class="text-slate-400">{t.labels.regreso}</span> <span class="font-bold text-orange-100 italic">{hornocal.regreso}</span>
              </div>
              <div class="flex justify-between border-b border-white/10 pb-3">
                <span class="text-slate-400">{t.labels.duracion}</span> <span class="font-bold text-orange-100 italic">{hornocal.duracion}</span>
              </div>
            </div>
            <p class="text-[11px] text-slate-500 italic mt-8 leading-relaxed">{t.disclaimer}</p>
          </div>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-[3rem] shadow-2xl shadow-slate-200 overflow-hidden border border-slate-100 flex flex-col transition-transform hover:scale-[1.01] duration-500">
      <div class="bg-cyan-700 p-10 md:p-14 text-white relative overflow-hidden">
        <div class="absolute right-0 top-0 opacity-10 text-9xl font-black -mr-10 -mt-10 select-none italic">SALINAS</div>
        <div class="flex flex-col md:flex-row justify-between items-start gap-8 relative z-10">
          <div>
            <h3 class="text-4xl md:text-5xl font-black italic leading-tight uppercase">{salinas[lang].titulo}</h3>
            <p class="text-cyan-100 text-xl mt-4 font-medium opacity-90">{salinas[lang].tag}</p>
          </div>

          <div class="bg-white/20 backdrop-blur-xl px-4 md:px-6 py-4 md:py-5 rounded-[2rem] text-center w-auto border border-white/30 shadow-xl flex flex-col items-center justify-center">
            <p class="text-[11px] uppercase font-black tracking-widest opacity-80 mb-1 whitespace-nowrap">{t.priceLabel}</p>
            
            <p class="text-3xl md:text-4xl font-black tracking-tighter leading-none whitespace-nowrap">
              {salinas.precio}
            </p>
            
            <p class="text-[10px] mt-2 uppercase font-bold tracking-widest whitespace-nowrap opacity-90">Hasta {salinas.pax} pasajeros</p>
          </div>
          
        </div>
      </div>

      <div class="grid grid-cols-3 gap-3 p-6 bg-slate-100">
        <div class="aspect-video overflow-hidden rounded-2xl border-4 border-white shadow-lg"><img src="/img/excursiones/salinas-piletas.webp" alt="Salinas" class="w-full h-full object-cover"></div>
        <div class="aspect-video overflow-hidden rounded-2xl border-4 border-white shadow-lg"><img src="/img/excursiones/cuesta-lipan.webp" alt="Lipan" class="w-full h-full object-cover"></div>
        <div class="aspect-video overflow-hidden rounded-2xl border-4 border-white shadow-lg"><img src="/img/excursiones/salinas-grandes-jujuy.webp" alt="Fotos" class="w-full h-full object-cover"></div>
      </div>

      <div class="p-10 md:p-14">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
          <div>
            <h4 class="font-black text-slate-900 text-2xl mb-8 flex items-center gap-3 italic">
              <span class="bg-cyan-700 text-white w-10 h-10 flex items-center justify-center rounded-xl text-sm">02</span>
              {t.itinerary}
            </h4>
            <ul class="space-y-5">
              {salinas[lang].itinerario.map(item => (
                <li class="flex items-center gap-4 text-slate-700 font-bold">
                  <span class="w-2 h-2 bg-cyan-600 rounded-full"></span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
          <div class="bg-slate-900 text-white p-10 rounded-[2.5rem] shadow-2xl transform lg:-rotate-2 hover:rotate-0 transition-transform duration-500">
            <h4 class="font-black text-2xl mb-6 italic text-cyan-400 uppercase">{t.infoTitle}</h4>
            <div class="space-y-4 font-medium">
              <div class="flex justify-between border-b border-white/10 pb-3">
                <span class="text-slate-400">{t.labels.duracion}</span> <span class="font-bold text-cyan-100 italic">{salinas.duracion}</span>
              </div>
              <div class="flex justify-between border-b border-white/10 pb-3">
                <span class="text-slate-400">{t.labels.horarios}</span> <span class="font-bold text-cyan-100 italic">{salinas.salida}</span>
              </div>
            </div>
            <p class="text-[11px] text-slate-500 italic mt-8 leading-relaxed">{t.disclaimer}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>