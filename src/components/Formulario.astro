---
// src/components/Formulario.astro
const { lang = 'es' } = Astro.props;

// Traducciones de la interfaz
const t = {
  es: {
    title: "Reserva tu aventura",
    subtitle: "Completá el formulario y te enviaremos el presupuesto detallado al instante por WhatsApp.",
    name: "Nombre Completo",
    destination: "Destino",
    date: "Fecha Estimada",
    passengers: "Pasajeros",
    button: "Consultar por WhatsApp",
    security: "🔒 Tus datos se envían de forma segura a través de WhatsApp.",
    service: "Atención 24/7"
  },
  en: {
    title: "Book your adventure",
    subtitle: "Complete the form and we will send you the detailed quote instantly via WhatsApp.",
    name: "Full Name",
    destination: "Destination",
    date: "Estimated Date",
    passengers: "Passengers",
    button: "Inquire via WhatsApp",
    security: "🔒 Your data is sent securely via WhatsApp.",
    service: "24/7 Support"
  }
}[lang];
---

<section id="contacto" data-lang={lang} class="py-24 px-6 bg-slate-900 overflow-hidden relative">
  <div class="absolute top-0 right-0 w-96 h-96 bg-orange-600/10 rounded-full blur-3xl -z-10"></div>
  
  <div class="max-w-4xl mx-auto bg-white rounded-[3rem] shadow-2xl overflow-hidden flex flex-col md:flex-row">
    
    <div class="bg-orange-600 md:w-1/3 p-12 text-white flex flex-col justify-center">
      <h2 class="text-3xl font-black mb-6 italic leading-tight">{t.title}</h2>
      <p class="text-orange-100 mb-8">{t.subtitle}</p>
      
      <div class="space-y-4">
        <div class="flex items-center gap-3">
          <span class="bg-white/20 p-2 rounded-lg text-xl">📍</span>
          <span class="text-sm font-bold">Salta & Jujuy</span>
        </div>
        <div class="flex items-center gap-3">
          <span class="bg-white/20 p-2 rounded-lg text-xl">⏰</span>
          <span class="text-sm font-bold">{t.service}</span>
        </div>
      </div>
    </div>

    <div class="p-8 md:p-12 md:w-2/3">
      <form id="reserva-form" class="space-y-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label class="block text-xs font-black uppercase text-slate-400 mb-2 tracking-widest">{t.name}</label>
            <input type="text" id="nombre" required placeholder="Ej: Juan Pérez" 
              class="w-full bg-slate-50 border border-slate-200 rounded-2xl px-4 py-4 focus:ring-2 focus:ring-orange-500 outline-none transition-all text-slate-900" />
          </div>
          <div>
            <label class="block text-xs font-black uppercase text-slate-400 mb-2 tracking-widest">{t.destination}</label>
            <select id="destino" class="w-full bg-slate-50 border border-slate-200 rounded-2xl px-4 py-4 focus:ring-2 focus:ring-orange-500 outline-none transition-all text-slate-900 font-medium">
              <option value="Hornocal">Cerro 14 Colores (Hornocal)</option>
              <option value="Salinas Grandes">Salinas Grandes</option>
              <option value="Aeropuerto Salta">Transfer Aeropuerto</option>
              <option value="Personalizado">Viaje a Medida / Otro</option>
            </select>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label class="block text-xs font-black uppercase text-slate-400 mb-2 tracking-widest">{t.date}</label>
            <input type="date" id="fecha" required 
              class="w-full bg-slate-50 border border-slate-200 rounded-2xl px-4 py-4 focus:ring-2 focus:ring-orange-500 outline-none transition-all text-slate-900" />
          </div>
          <div>
            <label class="block text-xs font-black uppercase text-slate-400 mb-2 tracking-widest">{t.passengers}</label>
            <input type="number" id="personas" min="1" max="4" value="2" 
              class="w-full bg-slate-50 border border-slate-200 rounded-2xl px-4 py-4 focus:ring-2 focus:ring-orange-500 outline-none transition-all text-slate-900" />
          </div>
        </div>

        <button type="submit" 
          class="w-full bg-slate-900 hover:bg-orange-600 text-white font-black py-5 rounded-2xl shadow-xl transition-all transform hover:-translate-y-1 active:scale-95 uppercase tracking-widest">
          {t.button}
        </button>
        
        <p class="text-[10px] text-center text-slate-400 uppercase font-bold tracking-tighter">
          {t.security}
        </p>
      </form>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('reserva-form') as HTMLFormElement;
  const section = document.getElementById('contacto');
  const lang = section?.getAttribute('data-lang') || 'es';

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    
    const nombre = (document.getElementById('nombre') as HTMLInputElement).value;
    const destino = (document.getElementById('destino') as HTMLSelectElement).value;
    const fecha = (document.getElementById('fecha') as HTMLInputElement).value;
    const personas = (document.getElementById('personas') as HTMLInputElement).value;
    
    const tel = "5493884153744"; // REEMPLAZAR CON EL NÚMERO REAL
    const fechaFormateada = fecha.split('-').reverse().join('/');
    
    // Lógica de mensaje bilingüe
    const mensaje = lang === 'en' 
      ? `Hello Remis El Chino! 👋 My name is *${nombre}*. \nI'd like to check availability for a transfer to *${destino}* on *${fechaFormateada}*. We are *${personas}* passengers. \nCould you please send me a quote?`
      : `Hola Remis El Chino! 👋 Mi nombre es *${nombre}*. \nMe gustaría consultar la disponibilidad para un traslado a *${destino}* para el día *${fechaFormateada}*. Seríamos *${personas}* pasajeros. \n¿Podrían pasarme el presupuesto?`;
    
    const url = `https://wa.me/${tel}?text=${encodeURIComponent(mensaje)}`;
    window.open(url, '_blank');
  });
</script>

<style>
  input[type="date"]::-webkit-calendar-picker-indicator {
    filter: invert(0.5);
    cursor: pointer;
  }
</style>