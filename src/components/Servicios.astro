---
const destinos = [
  { nombre: "Salinas Grandes", precio: "Consultar", img: "/salinas.jpg" },
  { nombre: "Cafayate", precio: "Consultar", img: "/cafayate.jpg" },
  { nombre: "Humahuaca", precio: "Consultar", img: "/humahuaca.jpg" },
];
---
<section class="py-16 px-4 max-w-6xl mx-auto">
  <h2 class="text-3xl font-bold text-center mb-10">Nuestros Recorridos Populares</h2>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
    {destinos.map(destino => (
      <div class="border rounded-xl overflow-hidden shadow-md hover:scale-105 transition">
        <img src={destino.img} alt={destino.nombre} class="h-48 w-full object-cover"/>
        <div class="p-4">
          <h3 class="font-bold text-xl">{destino.nombre}</h3>
          <p class="text-gray-600">Servicio puerta a puerta</p>
        </div>
      </div>
    ))}
  </div>
</section>